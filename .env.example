# Firebase Web SDK (safe to expose, restricted via Security Rules + App Check)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK service account (server only).
# Easiest: base64-encode the whole JSON file and paste it here.
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes('path\to\sa.json'))
#   bash:       base64 -w0 path/to/sa.json
FIREBASE_ADMIN_SERVICE_ACCOUNT_B64=
# Alternative: raw single-line JSON (escape internal quotes). Only one of the two is needed.
FIREBASE_ADMIN_SERVICE_ACCOUNT=
