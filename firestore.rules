rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function role() { return isSignedIn() ? request.auth.token.role : null; }
    function isAdmin() { return role() == 'admin'; }
    function isHospital() { return role() == 'hospital'; }
    function isDonor() { return role() == 'donor'; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    // User profiles. A user can read/update their own profile. Admins can read all.
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid)
                    && request.resource.data.role in ['donor','hospital'];
      allow update: if (isSelf(uid)
                       && request.resource.data.role == resource.data.role)
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // Donor records. Public can register from /donate. Anyone can read for matching display.
    // Updates/deletes restricted to the owning user or an admin.
    match /donors/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Blood requests. Public can submit from /request. Anyone can read live queue.
    match /requests/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin()
                    || (isHospital() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Inventory. Public read for the hospital dashboard; writes restricted.
    match /inventory/{id} {
      allow read: if true;
      allow write: if isHospital() || isAdmin();
    }

    // Drives. Public-readable; admins write.
    match /drives/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site settings doc(s). Public read; admin write.
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Newsletter signups. Public can subscribe; only admins can read/manage.
    match /newsletter/{id} {
      allow read: if isAdmin();
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() < 200;
      allow update, delete: if isAdmin();
    }
  }
}
